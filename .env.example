# Create a Notion integration: https://www.notion.so/my-integrations
# Share Companies, Opportunities, and Projects databases with the integration.
#
# Local: `pnpm dev` — `/api/stats` reads Notion. Set env on Vercel for production.
#
# Optional on projects for AR tile: number fields named AR, Accounts Receivable, Balance Due,
# or Outstanding; optional Days overdue / AR days overdue for red alerts.

NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: data source IDs (collection://… in Notion). Defaults match Webhouse OS.
# NOTION_COMPANIES_DATA_SOURCE_ID=
# NOTION_OPPORTUNITIES_DATA_SOURCE_ID=
# NOTION_PROJECTS_DATA_SOURCE_ID=

# Xero (optional) — Custom Connection only (premium, single org): client id + secret, no refresh token.
# The app uses accounting.transactions.read + accounting.reports.read (Profit & Loss). Re-authorise if you add scopes.
# https://developer.xero.com/documentation/guides/oauth2/custom-connections
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# Optional: UUID from Xero Developer → your app (if auto /connections lookup fails)
# XERO_TENANT_ID=
# XERO_REPORTING_TIMEZONE=Australia/Sydney

# Cash collection goals — SQLite file lives under this directory (default: ./data).
# On a read-only host, point to a writable path (e.g. a mounted volume).
# WEBHOUSE_DATA_DIR=
